# Collector
COLLECTOR_PORT=4000
COLLECTOR_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# NATS JetStream
NATS_URL=nats://localhost:4222
NATS_STREAM=clickstream

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Postgres (config store)
POSTGRES_URL=postgres://clickstream:clickstream@localhost:5432/clickstream

# Sites
NEXT_PUBLIC_COLLECTOR_URL=http://localhost:4000
